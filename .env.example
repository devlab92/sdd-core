# ─────────────────────────────────────────────────────────────
# .env.example — template for environment variables
#
# SECURITY RULES:
#   1. NEVER commit the real .env file. Only this .example is tracked.
#   2. Use *** for any sensitive value shown in docs or logs.
#   3. Keep secrets in a secret manager in production, not in files.
#   4. Reference these vars from ONE centralized config module.
#
# Copy this file to .env and fill in real values locally:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# Database (example)
DATABASE_URL=postgresql://user:***@localhost:5432/dbname

# Auth / secrets (example)
JWT_SECRET=***
API_KEY=***

# Third-party (example)
# STRIPE_SECRET_KEY=***
# OPENAI_API_KEY=***
