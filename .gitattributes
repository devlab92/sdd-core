# Normalize line endings: store LF in the repo, check out native on Windows.
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary files — never touch
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.xlsm binary
