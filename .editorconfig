# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Preserve trailing spaces used for Markdown hard line breaks
trim_trailing_whitespace = false

[*.{py}]
indent_size = 4

[*.{go}]
indent_style = tab

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
